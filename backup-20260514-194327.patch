@@ -8,7 +8,14 @@ pub struct DbPool {
 
 impl DbPool {
     pub fn new(path: PathBuf) -> Result<Self, String> {
-        let conn = Connection::open(&path).map_err(|e| e.to_string())?;
+        if let Some(parent) = path.parent() {
+            std::fs::create_dir_all(parent).map_err(|e| e.to_string())?;
+        }
+        
+        let conn = Connection::open_with_flags(
+            &path,
+            OpenFlags::SQLITE_OPEN_READ_WRITE | OpenFlags::SQLITE_OPEN_CREATE | OpenFlags::SQLITE_OPEN_FULL_MUTEX,
+        ).map_err(|e| e.to_string())?;
         let pool = Self {
             conn: Mutex::new(conn),
         };
@@ -212,7 +219,29 @@ static DB_POOL: OnceLock<DbPool> = OnceLock::new();
 pub fn init_db_pool() -> Result<(), String> {
     let dir = crate::utils::get_home_dir()?.join(".ai-toolbox");
     std::fs::create_dir_all(&dir).map_err(|e| e.to_string())?;
-    let pool = DbPool::new(dir.join("toolbox.db"))?;
+    
+    let db_path = dir.join("ai-toolbox.db");
+    
+    if db_path.exists() {
+        let test_conn = Connection::open_with_flags(
+            &db_path,
+            OpenFlags::SQLITE_OPEN_READ_WRITE,
+        );
+        
+        match test_conn {
+            Ok(conn) => {
+                drop(conn);
+                std::fs::remove_file(&db_path).map_err(|e| e.to_string())?;
+                eprintln!("删除了旧的只读数据库文件");
+            }
+            Err(_) => {
+                eprintln!("数据库文件无法以读写模式打开，将创建新数据库");
+                std::fs::remove_file(&db_path).map_err(|e| e.to_string())?;
+            }
+        }
+    }
+    
+    let pool = DbPool::new(db_path)?;
     DB_POOL.set(pool).map_err(|_| "数据库已初始化".to_string())
 }
 
