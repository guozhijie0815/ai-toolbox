{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AI Toolbox",
  "version": "0.2.1",
  "identifier": "cn.zdm.ai-toolbox",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev -- --host 0.0.0.0 --port 1420",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AI Toolbox",
        "width": 1600,
        "height": 980,
        "minWidth": 1320,
        "minHeight": 820,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
